

####
#
#Browse Airports
#

GET http://localhost:4004/odata/v4/catalog/Airport

###
#Browse for specific Airport

GET http://localhost:4004/odata/v4/catalog/Airport('MDE')

###
#Adding Airport 

POST http://localhost:4004/odata/v4/catalog/Airport
Content-Type: application/json

{    
    "ID": "MDE",
    "MANDT" : "300",
    "NAME": "Medellín, Colombia",
    "TIME_ZONE": "UTC-5"
}

###
#Borrado
#
DELETE http://localhost:4004/odata/v4/catalog/Airport('BOG')

###
#Update
#
PATCH  http://localhost:4004/odata/v4/catalog/Airport('MDE')
Content-Type: application/json

{
    "ID": "MDE",
    "MANDT" : "300",
    "NAME": "Medellín, Colombia SA",
    "TIME_ZONE": "UTC-5"
}

###
#Get Airport
#

GET http://localhost:4004/odata/v4/catalog/Airplane

###
#Get Airplane by ID
#
GET http://localhost:4004/odata/v4/catalog/Airplane('146-200')

###
#Get Airport Location
#

GET http://localhost:4004/odata/v4/catalog/AirportLocation

###
#Get GeoLocation
#
GET http://localhost:4004/odata/v4/catalog/GeoLocation

###
#Create new Geolocation
#
POST http://localhost:4004/odata/v4/catalog/GeoLocation
Content-Type: application/json

{    
    "CITY": "SANTA MARTA",
    "COUNTRY" : "CO",
    "LATITUDE": "11.1179",
    "LONGITUDE": "-74.2318"
}

###
#
#

GET http://localhost:4004/odata/v4/catalog/GeoLocation(CITY='BOGOTA',COUNTRY='CO')

