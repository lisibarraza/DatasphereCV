GET http://localhost:4004/odata/v4/catalog/Agency

###
#Service Get 
#

### Get Agency Sales Data
GET http://localhost:4004/odata/v4/catalog/getAgencySales(AGENCY_NUM='00000114',Date_From=2009-09-30,Date_To=2010-01-01)

###
#
#
GET http://localhost:4004/odata/v4/catalog/getAgency(AGENCY_NUM='00000114')

###
#
#
GET http://localhost:4004/odata/v4/catalog/Customer

###
#Testing the 
#
GET http://localhost:4004/odata/v4/catalog/getDatesRptSales

###
#Test SP
#
POST  http://localhost:4004/odata/v4/catalog/fillAgencySales(V_DATE_FROM='2010-01',V_DATE_TO='2011-01')

###
#GET CITIES
#
GET http://localhost:4004/odata/v4/catalog/City

###
#GET CITY CALLED
#
GET http://localhost:4004/odata/v4/catalog/City(CITY='COCHABAMBA',COUNTRY='BO',AIRPORT='CBB')

###
#POST A CITY
#
POST http://localhost:4004/odata/v4/catalog/City
Content-Type: application/json

{   
    "AIRPORT": "CBB", 
    "CITY": "COCHABAMBA",
    "COUNTRY" : "BO",    
    "MASTERCITY": "COCHABAMBA"
}

###
#Update
#
PATCH  http://localhost:4004/odata/v4/catalog/City(CITY='COCHABAMBA',COUNTRY='BO',AIRPORT='CBB')
Content-Type: application/json

{
    "AIRPORT": "CBB", 
    "CITY": "COCHABAMBA",
    "COUNTRY" : "BO",    
    "MASTERCITY": "COCHABAMBA",
    "MANDANT" : "300"
}

