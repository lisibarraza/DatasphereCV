<mvc:View controllerName="viewmapairports.controller.view_map_airports"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout" 
    xmlns:vbm="sap.ui.vbm" >
    <Page id="page" title="{i18n>title}">
    	<l:FixFlex id="_IDGenFixFlex" class="fixFlexVertical">
		<l:fixContent>
			<Panel id="_IDGenPanel" expandable="true" expanded="{= !${device>/system/phone} }"
				headerText="Description">
				<headerToolbar>
					<Toolbar id="_IDGenToolbar">
						<Title id="_IDGenTitle" text="Description" />
						<ToolbarSpacer id="_IDGenToolbarSpacer" />
						<Button id="btnResize" icon="sap-icon://resize" press="onPressResize"
							tooltip="Minimize" />
					</Toolbar>
				</headerToolbar>
				<content>
					<VBox id="_IDGenVBox1" class="sapUiTinyMargin">
						<Text id="_IDGenText1" class="sapUiTinyMarginTop" text="See also: " />
						<Link id="_IDGenLink" class="sapUiLargeMarginLeft" text="Click on the Airport you want more details from"
							target="_blank" href="test-resources/sap/ui/vbm/bestpractices.html" />
					</VBox>
				</content>
			</Panel>
		</l:fixContent>
		<l:flexContent>
			<vbm:AnalyticMap id="vbi" width="100%" xmlns:l="sap.ui.layout" height="100%"
				initialPosition="0;10;0" regionClick="onRegionClick"
				regionContextMenu="onRegionContextMenu">
				<vbm:vos>
					<vbm:Spots id="spots" items="{/AirportLocation}">
						<vbm:Spot 
							id= "spotAirport"
							position="{LONGITUDE};{LATITUDE};0"
							tooltip="{ID}"
							text="{CITY}, {COUNTRY_NAME}"
							type="Default" 
							icon="sap-icon://flight"
							click="onSpotClick"/>
					</vbm:Spots>
				</vbm:vos>
			</vbm:AnalyticMap>
		</l:flexContent>
	</l:FixFlex>
    </Page>
</mvc:View>