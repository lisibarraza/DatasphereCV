VIEW V_SPFLI
("CARRID", "CONNID", "COUNTRYFR", "CITYFROM", "AIRPFROM", "COUNTRYTO", "CITYTO", "AIRPTO", "FLTIME", "DEPTIME", "ARRTIME", "DISTANCE", "DISTID", "FLTYPE", "PERIOD")
AS
SELECT "CARRID", "CONNID", "COUNTRYFR", "CITYFROM", "AIRPFROM", "COUNTRYTO", "CITYTO", "AIRPTO", "FLTIME", "DEPTIME", "ARRTIME", "DISTANCE", "DISTID", "FLTYPE", "PERIOD"
FROM "SYN_SPFLI"
WHERE "MANDT" = 300