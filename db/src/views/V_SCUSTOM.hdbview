VIEW V_SCUSTOM
("ID", "NAME", "FORM", "STREET", "POSTBOX", "POSTCODE", "CITY", "COUNTRY", "REGION", "TELEPHONE", "CUSTTYPE", "DISCOUNT", "LANGU", "EMAIL", "WEBUSER")
AS
SELECT "ID", "NAME", "FORM", "STREET", "POSTBOX", "POSTCODE", "CITY", "COUNTRY", "REGION", "TELEPHONE", "CUSTTYPE", "DISCOUNT", "LANGU", "EMAIL", "WEBUSER"
FROM "SYN_SCUSTOM"
WHERE "MANDT" = 300