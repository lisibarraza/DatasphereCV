VIEW V_SBOOK
("CARRID", "CONNID", "FLDATE", "BOOKID", "CUSTOMID", "CUSTTYPE", "SMOKER", "LUGGWEIGHT", "WUNIT", "INVOICE", "CLASS", "FORCURAM", "FORCURKEY", "LOCCURAM", "LOCCURKEY", "ORDER_DATE", "COUNTER", "AGENCYNUM", "CANCELLED", "RESERVED", "PASSNAME", "PASSFORM", "PASSBIRTH")
AS
SELECT "CARRID", "CONNID", "FLDATE", "BOOKID", "CUSTOMID", "CUSTTYPE", "SMOKER", "LUGGWEIGHT", "WUNIT", "INVOICE", "CLASS", "FORCURAM", "FORCURKEY", "LOCCURAM", "LOCCURKEY", "ORDER_DATE", "COUNTER", "AGENCYNUM", "CANCELLED", "RESERVED", "PASSNAME", "PASSFORM", "PASSBIRTH"
FROM "SYN_SBOOK"
WHERE "MANDT" = 300