VIEW V_AIRPORT_LOCATION
(ID,CITY, COUNTRY_NAME, TIME_ZONE, LATITUDE, LONGITUDE)
AS
SELECT AP.ID, CTA.CITY, CT.COUNTRY_NAME, AP.TIME_ZONE, GC.LATITUDE, GC.LONGITUDE
FROM "V_SAIRPORT" AP
INNER JOIN "V_SCITAIRP" CTA ON AP.ID = CTA.AIRPORT
INNER JOIN "V_COUNTRY" CT ON CTA.COUNTRY = CT.COUNTRY
LEFT JOIN "V_SGEOCITY" GC ON CTA.COUNTRY = GC.COUNTRY AND CTA.CITY = GC.CITY