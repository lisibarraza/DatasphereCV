VIEW V_STRAVELAG
("AGENCYNUM", "NAME", "STREET", "POSTBOX", "POSTCODE", "CITY", "COUNTRY", "REGION", "TELEPHONE", "URL", "LANGU", "CURRENCY")
AS
SELECT  "AGENCYNUM", "NAME", "STREET", "POSTBOX", "POSTCODE", UPPER("CITY"), "COUNTRY", "REGION", "TELEPHONE", "URL", "LANGU", "CURRENCY"
FROM "SYN_STRAVELAG"
WHERE "MANDT" = 300