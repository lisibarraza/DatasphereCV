VIEW V_SAPLANE
("MANDT","PLANETYPE", "SEATSMAX", "CONSUM", "CON_UNIT", "TANKCAP", "CAP_UNIT", "WEIGHT", "WEI_UNIT", "SPAN", "SPAN_UNIT", "LENG", "LENG_UNIT", "OP_SPEED", "SPEED_UNIT", "PRODUCER", "SEATSMAX_B", "SEATSMAX_F")
AS 
SELECT "MANDT","PLANETYPE", "SEATSMAX", "CONSUM", "CON_UNIT", "TANKCAP", "CAP_UNIT", "WEIGHT", "WEI_UNIT", "SPAN", "SPAN_UNIT", "LENG", "LENG_UNIT", "OP_SPEED", "SPEED_UNIT", "PRODUCER", "SEATSMAX_B", "SEATSMAX_F"
FROM  "SYN_SAPLANE"
WHERE "MANDT" = 300
