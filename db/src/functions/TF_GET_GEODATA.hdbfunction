FUNCTION "TF_GET_GEODATA"()
    RETURNS TABLE(
        "ID" NVARCHAR(8),
        "GEO_POINT_3857" ST_POINT
    )
    LANGUAGE SQLSCRIPT AS
BEGIN
    RETURN
        SELECT 
             AG.AGENCYNUM AS "ID",
            ST_GEOMFROMTEXT('POINT(' || GC."LONGITUDE" || ' ' || GC."LATITUDE" || ')', 4326).ST_TRANSFORM(3857)  AS "GEO_POINT_3857"
        FROM 
        "V_STRAVELAG" AG 
        INNER JOIN "V_SGEOCITY"  GC ON AG.CITY = GC.CITY AND AG.COUNTRY = GC.COUNTRY;
END;